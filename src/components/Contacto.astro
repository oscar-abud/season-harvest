---
import IconoEmail from "../components/icons/email.jsx";
import Iconowsp from "../components/icons/wsp.jsx";
import type { Phone, TimeWork } from "../types/contact";
import { CONST_ENDPOINT_CONTACTOS } from '../services/constats';

let url: string = import.meta.env.API_URL

// Fetch
const response = await fetch(`${url}/${CONST_ENDPOINT_CONTACTOS}`);
const contactData = await response.json();

// Si es un Singleton, tomamos el primer (y único) contacto
const mainContact = contactData;
const phoneNumber = mainContact ? mainContact.phone : '-';

// Agregamos una validación simple para que no rompa si la API falla
if (!mainContact) {
  console.error("No se pudo cargar la información de contacto");
}

const formatChileanNumber = (num: number) => {
  const s = num.toString();
  const first = s.slice(0, 1);
  const mid = s.slice(1, 5);
  const last = s.slice(5);
  
  return `+56 (${first}) ${mid} ${last}`;
};
---

<section id="contacto" class="contacto">

  <div class="contacto-header">
    <span class="contacto-eyebrow">Contacto</span>
    <h2>¿Hablamos? <span>Estamos aquí.</span></h2>
    <p>Escríbenos por cualquiera de estos medios y te responderemos a la brevedad.</p>
  </div>

  <div class="contacto-panel">

    <!-- Columna izquierda: canales de comunicación -->
    <div class="contacto-col">
      <p class="contacto-col-label">Comunícate</p>

      <a href="mailto:seasonharvest99@gmail.com" target="_blank" class="contacto-item">
        <div class="contacto-item-icon icon-green">
          <IconoEmail />
        </div>
        <div class="contacto-item-body">
          <span class="contacto-item-label">Correo electrónico</span>
          <span class="contacto-item-value">seasonharvest99@gmail.com</span>
        </div>
      </a>

      {
        phoneNumber.map((phone: Phone) => (
          /* Nota: En wa.me es mejor no usar el "+" ni espacios, solo números */
          <a href={`https://wa.me/56${phone.phone}`} target="_blank" rel="noopener noreferrer" class="contacto-item">
            <div class="contacto-item-icon icon-wsp">
              <Iconowsp />
            </div>
            <div class="contacto-item-body">
              <span class="contacto-item-label">WhatsApp - {phone.name}</span>
              <span class="contacto-item-value">{formatChileanNumber(phone.phone)}</span>
            </div>
          </a>
        ))
      }
    </div>

    <!-- Columna derecha: información -->
    <div class="contacto-col">
      <p class="contacto-col-label">Información</p>

      {/* UBICACIÓN DINÁMICA */}
      <a href={`https://www.google.com/maps/search/${encodeURIComponent(mainContact.direction)}`} target="_blank" rel="noopener noreferrer" class="contacto-item">
        <div class="contacto-item-icon icon-green">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0d5a48" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 10c0 6-8 13-8 13S4 16 4 10a8 8 0 1 1 16 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <div class="contacto-item-body">
          <span class="contacto-item-label">Ubicación</span>
          <span class="contacto-item-value">{mainContact.direction}</span>
        </div>
      </a>

      {/* HORARIO DINÁMICO */}
      <div class="contacto-item">
        <div class="contacto-item-icon icon-amber">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ef9a18" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <div class="contacto-item-body">
          <span class="contacto-item-label">Horario de atención</span>
          {mainContact.timeWork.map((tw: TimeWork) => (
            <>
              <span class="contacto-item-value">{tw.days}</span>
              {tw.schedule.map((s) => (
                <span class="contacto-item-sub">{s.open} – {s.close}</span>
              ))}
            </>
          ))}
        </div>
      </div>
    </div>

  </div>

</section>
