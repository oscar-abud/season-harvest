---
import IconGitHub from "../components/icons/github.jsx";
import IconInstagram from "../components/icons/instagram.jsx";
import IconFacebook from "../components/icons/facebook.jsx";
---

<footer class="footer">

  <div class="footer-top">
    <div class="footer-brand">
      <span class="footer-logo-text">Season Harvest</span>
      <p class="footer-tagline">Verduras y frutas frescas directo a tu puerta, cada viernes.</p>
    </div>

    <!-- <div class="footer-links">
      <p class="footer-links-label">Navegación</p>
      <nav class="footer-nav">
        <a href="/#inicio">Inicio</a>
        <a href="/#Producto">Productos</a>
        <a href="/#nosotros">Nosotros</a>
        <a href="/#contacto">Contacto</a>
        <a href="/clientes">Para Clientes</a>
      </nav>
    </div> -->

    <div class="footer-social">
      <p class="footer-links-label">Redes sociales</p>
      <div class="footer-social-icons">
        <a href="https://www.instagram.com/seasonharvestcl/" target="_blank" rel="noopener noreferrer" class="footer-social-link">
          <IconInstagram />
          <span>Instagram</span>
        </a>
        <a href="https://www.facebook.com/profile.php?id=61574804046798" target="_blank" rel="noopener noreferrer" class="footer-social-link">
          <IconFacebook />
          <span>Facebook</span>
        </a>
