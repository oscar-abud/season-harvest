---
import Nav from "../components/Nav.astro";
interface Props {
  showImg?: boolean;
}

const { showImg = true } = Astro.props;
---

<link rel="stylesheet" href="/public/styles/header.css" />

<Nav />

<header id="header">
  {showImg && (
    <img class="logo" src="/images/logo.png" alt="Logo" />
  )}
</header>
