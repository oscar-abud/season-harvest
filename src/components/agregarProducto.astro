---
import type { ProductExtra } from '../types/products'
const { products = {} } = Astro.props;

import WspIcon from "../components/icons/wsp";
---

<div class="agregar-card">
    <div class="agregar-card-accent"></div>

    <div class="agregar-card-header">
        <div class="agregar-card-icon">🛒</div>
        <div class="agregar-card-header-text">
            <h2 class="agregar-card-title">{products.name}</h2>
            <p class="agregar-card-desc">{products.description}</p>
        </div>
    </div>

    <div class="agregar-product-list">
        <ul class="agregar-lista">
            {
                products.productosExtras?.map((item: ProductExtra) => (
                    <li>
                        <div class="agregar-item-left">
                            <span class="agregar-item-name">{item.name}</span>
                            <span class="agregar-item-meta">{item.quantity} {item.type}</span>
                        </div>
                        <span class="agregar-item-price">${item.price.toLocaleString('es-CL')}</span>
                    </li>
                ))
            }
        </ul>
    </div>

    <div class="agregar-price-box">
        <a
            class="agregar-wsp-btn"
            href="https://wa.me/+56966177010?text=Hola,%20quisiera%20obtener%20más%20información%20sobre%20cómo%20agregar%20productos%20a%20mi%20box."
            target="_blank"
            rel="noopener noreferrer"
        >
            <WspIcon />
            Consultar por productos
        </a>
    </div>
</div>
