---
import IconoWsp from "../components/icons/wsp.jsx";
import type { Product } from "../types/products";

const { title, precio, tipoBox, productos = [] } = Astro.props;


const formatPrecio = (precio: number) =>
  precio.toLocaleString("es-CL");

const formatCantidad = (cantidad: number) => {
  if (cantidad === 0.25) return "1/4";
  if (cantidad === 0.5) return "1/2";
  if (cantidad === 0.75) return "3/4";
  return cantidad; // Si es un entero como 1, 2 o 3, lo deja igual
};
---

<div class="product-card">
    <div class="card-header">
        <img src="/images/logo.png" alt="Season Harvest" class="card-logo" />
        <h2 class="card-title">{title}</h2>
    </div>

    <div class="product-list">
        <h3 class="list-label">
            <span class="dot"></span>
            Lista de Productos
            <span class="dot"></span>
        </h3>
        <ul class="listaProductos">
            {
                productos.map((item: Product) => (
                    <li>
                        <b>{formatCantidad(item.cantidad)}</b>{" "}
                        <span class="tipo">{item.tipo}</span>{" "}
                        {item.name}
                    </li>
                ))
            }
        </ul>
    </div>

    <div class="price-box">
        <a
            class="wsp-btn"
            href={`https://wa.me/+56966177010?text=Hola,%20quisiera%20solicitar%20el%20${encodeURIComponent(tipoBox)}.`}
            target="_blank"
            rel="noopener noreferrer"
        >
            <IconoWsp className="blanco" />
            Quiero este producto
        </a>
        <div class="price-tag">
            <p class="precio-label">Valor Box</p>
            <p class="precio-valor">${formatPrecio(precio)}</p>
        </div>
    </div>
</div>

<style>
    /* ── Card base ── */
    .product-card {
        background-color: var(--white-color);
        border-radius: 1.4rem;
        box-shadow:
            0 10px 30px rgba(0, 0, 0, 0.12),
            0 2px 8px rgba(0, 0, 0, 0.06);
        font-family: sans-serif;
        color: var(--dark-color);
        width: 400px;
        max-width: 100%;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .product-card:hover {
        transform: translateY(-5px);
        box-shadow:
            0 18px 40px rgba(0, 0, 0, 0.15),
            0 4px 12px rgba(0, 0, 0, 0.08);
    }

    /* ── Header ── */
    .card-header {
        background: linear-gradient(150deg, #0d5a48 0%, #1a7a5e 60%, #2a9a72 100%);
        padding: 1.5rem 1.5rem 1.2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.6rem;
        position: relative;
    }

    .card-header::after {
        content: "";
        position: absolute;
        bottom: -1px;
        left: 0;
        right: 0;
        height: 18px;
        background: var(--white-color);
        border-radius: 50% 50% 0 0 / 100% 100% 0 0;
    }

    .card-logo {
        width: 70px;
        height: 70px;
        object-fit: contain;
        border-radius: 50%;
        background: white;
        padding: 4px;
        box-shadow: 0 3px 10px rgba(0, 0, 0, 0.25);
    }

    .card-title {
        font-size: 1.35rem;
        font-weight: 800;
        color: #ffffff;
        text-align: center;
        margin: 0;
        letter-spacing: 0.6px;
        text-shadow: 0 1px 4px rgba(0, 0, 0, 0.25);
    }

    /* ── Product list ── */
    .product-list {
        flex: 1;
        padding: 1.4rem 1.4rem 0.6rem;
    }

    .list-label {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        background: linear-gradient(135deg, var(--green-color), #1a7a5e);
        color: var(--white-color);
        padding: 0.45rem 1rem;
        font-size: 0.82rem;
        border-radius: 50px;
        margin-bottom: 1rem;
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-align: center;
    }

    .dot {
        display: inline-block;
        width: 5px;
        height: 5px;
        background: var(--white-color);
        border-radius: 50%;
        opacity: 0.7;
    }

    .listaProductos {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 0.4rem;
        list-style: none;
        padding: 0;
        margin: 0;
    }

    li {
        font-size: 0.88rem;
        margin-bottom: 0.35rem;
        padding: 0.2rem 0.4rem;
        border-radius: 5px;
        transition: background 0.15s;
        line-height: 1.4;
        text-align: left;
    }

    li:hover {
        background-color: rgba(13, 90, 72, 0.06);
    }

    li b {
        color: var(--dark-color);
    }

    .tipo {
        font-weight: 700;
        color: var(--green-color);
    }

    /* ── Price box ── */
    .price-box {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.9rem 1.4rem 1.2rem;
        margin-top: 0.6rem;
        background: var(--cream-color);
        border-top: 2px solid rgba(13, 90, 72, 0.1);
    }

    .wsp-btn {
        display: flex;
        gap: 6px;
        align-items: center;
        padding: 9px 15px;
        background: linear-gradient(135deg, var(--green-color), #1a7a5e);
        border-radius: 50px;
        text-decoration: none;
        color: var(--white-color);
        font-weight: 700;
        font-size: 0.85rem;
        box-shadow: 0 3px 10px rgba(13, 90, 72, 0.35);
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease;
    }

    .wsp-btn:hover {
        transform: scale(1.05);
        box-shadow: 0 5px 16px rgba(13, 90, 72, 0.45);
    }

    .price-tag {
        text-align: right;
    }

    .precio-label {
        font-size: 0.72rem;
        color: #888;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 0 0 1px;
    }

    .precio-valor {
        color: var(--green-color);
        font-size: 1.6rem;
        font-weight: 900;
        margin: 0;
        line-height: 1;
    }

    @media screen and (max-width: 1085px) {
        .product-card {
            width: 100%;
            margin: 16px auto;
        }
    }
</style>
