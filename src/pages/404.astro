---
import Layout from "../layouts/layout.astro";
---

<Layout
    title="Página no encontrada | Season Harvest"
    nameContent="Error 404 | Página no encontrada"
    contenido="Ups, parece que tenemos un problema, es mejor que volvamos al inicio."
>
    <div class="page-404">
        <span class="error-code">404</span>
        <h1>Página no encontrada</h1>
        <p>La página que buscas no existe o fue movida.</p>
        <div class="actions">
            <button class="btn-back" onclick="history.back()">← Volver atrás</button>
            <a class="btn-home" href="/">Ir al inicio</a>
        </div>
    </div>
</Layout>
